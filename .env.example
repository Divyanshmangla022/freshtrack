# ---------------------------------------------------------------------------
# FreshTrack environment configuration (copy relevant blocks into server/.env)
# ---------------------------------------------------------------------------

# --- Server ---
PORT=4000
# CORS origin for the web client. In dev the Vite proxy is used, so "*" is fine.
CORS_ORIGIN=*

# --- Auth ---
# Generate a strong secret in production: `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`
JWT_SECRET=change-me-in-production
# Session/token lifetime (e.g. 15m, 8h, 12h).
TOKEN_TTL=12h

# --- Database ---
# SQLite file path (relative to the server package). Directory is created automatically.
DATABASE_FILE=./data/freshtrack.db

# --- Seed (used only by `npm run seed`) ---
SEED_ADMIN_EMAIL=admin@freshtrack.io
SEED_ADMIN_PASSWORD=Admin@12345
SEED_HUB_PASSWORD=Hub@12345

# --- AI enhancements (OPTIONAL — Google Gemini) ---
# Leave GEMINI_API_KEY unset to run fully offline — AI features degrade to
# deterministic heuristics (fuzzy column mapping) and the assistant is disabled.
# Get a key at https://aistudio.google.com/apikey
# GEMINI_API_KEY=...
# Note: gemini-2.5-pro is NOT available on the Gemini free tier (quota 0).
# Use gemini-2.5-flash unless you are on a paid tier.
AI_MAPPING_MODEL=gemini-2.5-flash
AI_ASSISTANT_MODEL=gemini-2.5-flash
